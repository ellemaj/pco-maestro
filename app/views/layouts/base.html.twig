<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="author" content="Elmar van Loenhout">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">

    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/x-icon" href="favicon/favicon.ico">

    {% block styles %}{% endblock %}
    {% block scripts %}{% endblock %}

    <title> {% block title %}{% endblock %}</title>
</head>

<body>

    <header>
        <a href="index.html"><img src="/images/logo.png" width="10%" alt="Logo"></a>
    </header>

    <nav class="menu">
        <ul>
            <li><a href="/" class="active">Home</a></li>
            <li><a href="/profile">Profile</a></li>
            <li><a href="/dashboard">Dashboard</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/blog">Blog</a></li>
        </ul>
    </nav>

    <!-- Content -->
    <main>
        {% block content %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-white dark:bg-[#161b22] border-t border-slate-200 dark:border-[#30363d]">
        <div class="max-w-6xl mx-auto px-6 py-4 text-center text-sm text-slate-500 dark:text-[#8b949e]">
            © {{ "now"|date("Y") }} ellemaj |
            <a href="mailto:loen0029@hz.nl">Contact</a> |
            <a href="sitemap">Sitemap</a> |
            <a href="commandmaker">Commandmaker</a>
        </div>
    </footer>
</body>
</html>
